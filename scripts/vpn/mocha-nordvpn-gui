#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:/etc/profiles/per-user/$USER/bin:/run/current-system/sw/bin:$PATH"

LOGDIR="${XDG_STATE_HOME:-$HOME/.local/state}/mocha-nordvpn-gui"
mkdir -p "$LOGDIR"

if ! command -v nordvpn-gui >/dev/null 2>&1; then
  echo "ERRO: nordvpn-gui nao encontrado nesta geracao." | tee -a "$LOGDIR/gui.log"
  exit 1
fi

if ! systemctl is-active --quiet nordvpnd.service; then
  sudo systemctl start nordvpnd.service
  sleep 2
fi

if ! pgrep -u "$USER" -x norduserd >/dev/null 2>&1; then
  if command -v norduserd >/dev/null 2>&1; then
    nohup norduserd >>"$LOGDIR/norduserd.log" 2>&1 &
  else
    NORDVPN_BIN="$(readlink -f "$(command -v nordvpn)")"
    CANDIDATE="$(dirname "$NORDVPN_BIN")/norduserd"
    if [ -x "$CANDIDATE" ]; then
      nohup "$CANDIDATE" >>"$LOGDIR/norduserd.log" 2>&1 &
    fi
  fi
  sleep 1
fi

{
  echo
  echo "===== $(date) ====="
  echo "nordvpn status:"
  nordvpn status || true
  echo
  echo "processos:"
  pgrep -a -i 'nord|vpn' || true
  echo
  echo "socket:"
  ls -ld /run/nordvpn /run/nordvpn/nordvpnd.sock 2>/dev/null || true
} >>"$LOGDIR/gui.log" 2>&1

exec nordvpn-gui "$@" >>"$LOGDIR/gui.log" 2>&1
