# /etc/nixos/modules/maintenance.nix

{
  services.fstrim.enable = true;
  services.fprintd.enable = true;

  # Usa o cache local do vmstore como fonte extra de pacotes já buildados.
  #
  # Importante:
  # - isto NÃO faz o sistema depender de configuração em /mnt/vmstore;
  # - /etc/nixos continua sendo a fonte operacional ativa;
  # - o vmstore entra apenas como cache/substituter;
  # - se o cache local não tiver algo, o Nix ainda pode buscar nos caches normais.
  nix.settings.extra-substituters = [
    "file:///mnt/vmstore/nix-cache?trusted=true"
  ];

  nix.gc = {
    automatic = true;
    dates = "weekly";
    options = "--delete-older-than 7d";
  };

  nix.optimise = {
    automatic = true;
    dates = [ "weekly" ];
  };

  # Corrige porta USB defeituosa / instável que fica gerando spam no kernel:
  #
  #   usb usb6-port2: Cannot enable. Maybe the USB cable is bad?
  #   usb usb6-port2: config error
  #
  # Teste aprovado em 2026-04-25:
  #   echo 1 > /sys/devices/pci0000:00/0000:00:08.1/0000:09:00.4/usb6/6-0:1.0/usb6-port2/disable
  #
  # Resultado:
  #   disable = 1
  #   nenhum novo erro usb6-port2 após o marcador.
  systemd.services.mocha-disable-bad-usb-port = {
    description = "Disable unstable USB6 port2 on Diesel OS Lab Mocha";

    wantedBy = [ "multi-user.target" ];
    after = [ "systemd-udev-settle.service" ];
    wants = [ "systemd-udev-settle.service" ];

    serviceConfig = {
      Type = "oneshot";
      RemainAfterExit = true;
    };

    script = ''
      port="/sys/devices/pci0000:00/0000:00:08.1/0000:09:00.4/usb6/6-0:1.0/usb6-port2/disable"

      if [ -e "$port" ]; then
        echo 1 > "$port"
        echo "Mocha: usb6-port2 desativada."
      else
        echo "Mocha: usb6-port2 nao encontrada neste boot; nada a fazer."
      fi
    '';
  };

  # Reaplica a correção depois de suspensão/hibernação, caso o kernel reavalie
  # a porta USB no retorno da energia.
  powerManagement.resumeCommands = ''
    port="/sys/devices/pci0000:00/0000:00:08.1/0000:09:00.4/usb6/6-0:1.0/usb6-port2/disable"

    if [ -e "$port" ]; then
      echo 1 > "$port"
      echo "Mocha: usb6-port2 redesativada apos resume."
    fi
  '';
}
