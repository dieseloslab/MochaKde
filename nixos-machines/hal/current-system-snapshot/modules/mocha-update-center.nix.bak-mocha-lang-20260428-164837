    fn normalize_lang(raw: &str) -> String {
        let base = raw
            .split('.')
            .next()
            .unwrap_or(raw)
            .split('@')
            .next()
            .unwrap_or(raw)
            .trim();

        match base {
            "pt_BR" | "pt" => "pt_BR".to_string(),
            "en_US" | "en_GB" | "en" => "en_US".to_string(),
            "es_ES" | "es_MX" | "es_AR" | "es" => "es_ES".to_string(),
            "fr_FR" | "fr_CA" | "fr" => "fr_FR".to_string(),
            _ => "en_US".to_string(),
        }
    }

    fn detect_lang() -> String {
        for key in ["LC_ALL", "LC_MESSAGES", "LANG"] {
            if let Ok(value) = env::var(key) {
                if !value.trim().is_empty() && value.trim() != "C" && value.trim() != "POSIX" {
                    return normalize_lang(&value);
                }
            }
        }

        "en_US".to_string()
    }

