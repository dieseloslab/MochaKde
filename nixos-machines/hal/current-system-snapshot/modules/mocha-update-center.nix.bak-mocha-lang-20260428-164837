    fn zenity_error(lang: &str, text: &str) {
        let _ = Command::new(ZENITY)
            .arg("--error")
            .arg("--width=680")
            .arg(format!("--title={}", t(lang, "title")))
            .arg(format!("--text={}", text))
            .stdout(Stdio::null())
            .stderr(Stdio::null())
            .status();
    }

    fn zenity_info(lang: &str, text: &str) {
        let _ = Command::new(ZENITY)
            .arg("--info")
            .arg("--width=680")
            .arg(format!("--title={}", t(lang, "title")))
            .arg(format!("--text={}", text))
            .stdout(Stdio::null())
            .stderr(Stdio::null())
            .status();
    }

    fn choose_action(lang: &str) -> Option<String> {
        let mut command = Command::new(ZENITY);

        command
            .arg("--list")
            .arg("--radiolist")
            .arg("--width=980")
            .arg("--height=560")
            .arg(format!("--title={}", t(lang, "title")))
            .arg(format!("--text={}", t(lang, "intro")))
            .arg(format!("--ok-label={}", t(lang, "install_button")))
            .arg(format!("--cancel-label={}", t(lang, "cancel_button")))
            .arg("--print-column=2")
            .arg("--hide-column=2")
            .arg(format!("--column={}", t(lang, "column_choose")))
            .arg(format!("--column={}", t(lang, "column_id")))
            .arg(format!("--column={}", t(lang, "column_action")))
            .arg(format!("--column={}", t(lang, "column_desc")));

        let actions = actions();

        for (idx, action) in actions.iter().enumerate() {
            let checked = if idx == 0 { "TRUE" } else { "FALSE" };

            command
                .arg(checked)
                .arg(action.id)
                .arg(t(lang, action.title_key))
                .arg(t(lang, action.desc_key));
        }

        let output = match command.output() {
            Ok(output) => output,
            Err(err) => {
                zenity_error(lang, &format!("{}:\n{}", t(lang, "auth_error"), err));
                return None;
            }
        };

        if !output.status.success() {
            return None;
        }

        let selected = String::from_utf8_lossy(&output.stdout).trim().to_string();

        if selected.is_empty() {
            None
        } else {
            Some(selected)
        }
    }

    fn write_script(action: &str, log_path: &str, script_path: &str) -> Result<(), String> {
        let body = match action {
            "safe-maintenance" => format!(
                r#"
echo "===== Mocha Update Center: safe maintenance ====="
echo
echo "Garantindo Flathub global..."
if ! "{flatpak}" remotes --system --columns=name | "{grep}" -qx 'flathub'; then
  "{flatpak}" remote-add --system --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
fi

echo
echo "Atualizando Flatpaks do sistema..."
"{flatpak}" update --system -y

echo
echo "Validando sistema atual..."
cd /etc/nixos
export NIX_CONFIG='experimental-features = nix-command flakes'
"{nixos_rebuild}" test --flake /etc/nixos#diesel-os-lab --show-trace

echo
echo "Reaplicando configuração atual..."
"{nixos_rebuild}" switch --flake /etc/nixos#diesel-os-lab --show-trace
"#,
                flatpak = FLATPAK,
                grep = GREP,
                nixos_rebuild = NIXOS_REBUILD,
            ),
            "flatpak-update" => format!(
                r#"
echo "===== Mocha Update Center: flatpak update ====="
echo
echo "Garantindo Flathub global..."
if ! "{flatpak}" remotes --system --columns=name | "{grep}" -qx 'flathub'; then
  "{flatpak}" remote-add --system --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
fi

echo
echo "Atualizando Flatpaks do sistema..."
"{flatpak}" update --system -y
"#,
                flatpak = FLATPAK,
                grep = GREP,
            ),
            "nixos-test" => format!(
                r#"
echo "===== Mocha Update Center: nixos-rebuild test ====="
cd /etc/nixos
export NIX_CONFIG='experimental-features = nix-command flakes'
"{nixos_rebuild}" test --flake /etc/nixos#diesel-os-lab --show-trace
"#,
                nixos_rebuild = NIXOS_REBUILD,
            ),
            "nixos-switch" => format!(
                r#"
echo "===== Mocha Update Center: nixos-rebuild switch ====="
cd /etc/nixos
export NIX_CONFIG='experimental-features = nix-command flakes'
"{nixos_rebuild}" switch --flake /etc/nixos#diesel-os-lab --show-trace
"#,
                nixos_rebuild = NIXOS_REBUILD,
            ),
            _ => {
                return Err(format!("Unsupported action: {}", action));
            }
        };

        let script = format!(
            r#"#!/usr/bin/env bash
set -euo pipefail

LOG="{log}"

{{
{body}

echo
echo "Ação concluída com sucesso."
}} > "$LOG" 2>&1
"#,
            log = log_path,
            body = body,
        );

        fs::write(script_path, script)
            .map_err(|err| format!("Failed to write script: {}", err))
    }

    fn tail_log(lang: &str, log_path: &str, lines: usize) -> String {
        let content = fs::read_to_string(log_path).unwrap_or_else(|_| String::new());

        if content.trim().is_empty() {
            return format!("{}:\n{}", t(lang, "log_empty"), log_path);
        }

        let all_lines: Vec<&str> = content.lines().collect();
        let start = all_lines.len().saturating_sub(lines);

        all_lines[start..].join("\n")
    }

    fn run_root_action(lang: &str, action: &str) {
        let pid = std::process::id();
        let log_path = format!("/tmp/mocha-update-center-{}.log", pid);
        let script_path = format!("/tmp/mocha-update-center-{}.sh", pid);

        if let Err(err) = write_script(action, &log_path, &script_path) {
            zenity_error(lang, &err);
            return;
        }

        let mut progress = Command::new(ZENITY)
            .arg("--progress")
            .arg("--pulsate")
            .arg("--no-cancel")
            .arg("--width=560")
            .arg(format!("--title={}", t(lang, "title")))
            .arg(format!("--text={}", t(lang, "progress")))
            .stdout(Stdio::null())
            .stderr(Stdio::null())
            .spawn()
            .ok();

        let status = Command::new(PKEXEC)
            .arg(BASH)
            .arg(&script_path)
            .status();

        if let Some(child) = progress.as_mut() {
            let _ = child.kill();
            let _ = child.wait();
        }

        thread::sleep(Duration::from_millis(250));

        match status {
            Ok(exit_status) if exit_status.success() => {
                zenity_info(lang, t(lang, "success"));
            }
            Ok(exit_status) => {
                let tail = tail_log(lang, &log_path, 120);
                zenity_error(
                    lang,
                    &format!("{}\n\nStatus: {}\n\n{}", t(lang, "failed"), exit_status, tail),
                );
            }
            Err(err) => {
                zenity_error(
                    lang,
                    &format!(
                        "{}:\n{}\n\n/run/wrappers/bin/pkexec",
                        t(lang, "auth_error"),
                        err
                    ),
                );
            }
        }
    }

    fn show_generations(lang: &str) {
        let output = Command::new(NIXOS_REBUILD)
            .arg("list-generations")
            .output();

        let text = match output {
            Ok(output) => {
                let mut combined = String::new();
                combined.push_str(&String::from_utf8_lossy(&output.stdout));
                combined.push_str(&String::from_utf8_lossy(&output.stderr));

                if combined.trim().is_empty() {
                    t(lang, "log_empty").to_string()
                } else {
                    combined
                }
            }
            Err(err) => format!("{}:\n{}", t(lang, "auth_error"), err),
        };

        let path = format!("/tmp/mocha-update-center-generations-{}.txt", std::process::id());

        if fs::write(&path, text).is_err() {
            zenity_error(lang, t(lang, "log_empty"));
            return;
        }

        let _ = Command::new(ZENITY)
            .arg("--text-info")
            .arg("--width=760")
            .arg("--height=520")
            .arg(format!("--title={}", t(lang, "generations_title")))
            .arg(format!("--filename={}", path))
            .stdout(Stdio::null())
            .stderr(Stdio::null())
            .status();
    }

    fn main() {
        let lang = detect_lang();

        if !Path::new("/etc/nixos").exists() {
            zenity_error(&lang, t(&lang, "no_nixos"));
            std::process::exit(1);
        }

        let selected = match choose_action(&lang) {
            Some(selected) => selected,
            None => return,
        };

        if selected == "upgrade-locked" {
            zenity_info(&lang, t(&lang, "upgrade_locked_text"));
            return;
        }

        if selected == "generations" {
            show_generations(&lang);
            return;
        }

        let action = actions()
            .into_iter()
            .find(|action| action.id == selected);

        match action {
            Some(action) if action.requires_root => run_root_action(&lang, action.id),
            Some(_) => zenity_error(&lang, "Unsupported non-root action."),
            None => zenity_error(&lang, "Unknown action."),
        }
    }
  '';

  mochaUpdateCenter = pkgs.runCommand "mocha-update-center" {
    nativeBuildInputs = [
      pkgs.rustc
      pkgs.stdenv.cc
    ];
  } ''
    mkdir -p "$out/bin"
    rustc ${mochaUpdateCenterSrc} -O \
      -C linker=${pkgs.stdenv.cc}/bin/cc \
      -o "$out/bin/mocha-update-center"
  '';

  mochaUpdateCenterDesktop = pkgs.makeDesktopItem {
    name = "mocha-update-center";
    desktopName = "Mocha Update Center";
    genericName = "System Update Center";
    comment = "Update and maintain Diesel OS Lab - GNOME Mocha Edition";
    exec = "mocha-update-center";
    icon = "system-software-update";
    terminal = false;
    categories = [
      "System"
      "Settings"
    ];
  };
in
{
  environment.systemPackages = [
    mochaUpdateCenter
    mochaUpdateCenterDesktop
  ];
}
